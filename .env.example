# ── Dominion Utility Automation — environment template ──────────────────────────
# Copy to `.env` and fill in. NEVER commit the real .env (it is gitignored).

# ── PostgreSQL (Abdul's DB — single source of truth for WS-1/2/3/4) ─────────────
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=false
# DB_OFFLINE=1   # force audit-log writes to cache/*.jsonl instead of Postgres

# ── BGE portal (WS-3) ───────────────────────────────────────────────────────────
BGE_EMAIL=
BGE_PASSWORD=
BGE_LOGIN_URL=https://myaccount.bge.com/sign-in
# BGE_MODE=audit|paperless|bills|pay|full   (set per run; defaults to full)
# BGE_INPUT_CSV=cache/all-dominion-addresses.csv
# BGE_RESULTS_CSV=cache/all-dominion-addresses-results.csv

# ── Baltimore Water portal (WS-4) ───────────────────────────────────────────────
WATER_EMAIL=
WATER_PASSWORD=
WATER_LOGIN_URL=https://waterbillportal.baltimorecity.gov
# WATER_MODE=audit|paperless|bills|pay|full
# WATER_LIMIT=0   # >0 caps the number of units processed (smoke tests)

# ── Payment runs (WS-3/WS-4 'pay' mode) ─────────────────────────────────────────
# Ties payments to a WS-2 run's payment_approval rows. Required for pay mode.
RUN_ID=

# ── OTP via Microsoft Graph (shared Outlook mailbox; BGE + Water) ───────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
BGE_OTP_MAILBOX=construction@thedominiongroup.com
BGE_OTP_SENDER=no-reply@bge.com
WATER_OTP_MAILBOX=construction@thedominiongroup.com
WATER_OTP_SENDER=no-reply@baltimorecity.gov
# Legacy IMAP OTP fallback (BGE only):
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_EMAIL=
# IMAP_PASSWORD=

# ── WS-2 routing + proration knobs (all optional; defaults in routingEngine.ts) ─
# WS2_VACANT_MAX_USAGE=10
# WS2_RENOVATION_VACANT_MAX_USAGE=30
# WS2_LETTER_MULTIPLIER=1.5
# WS2_WORK_ORDER_MULTIPLIER=3
# WS2_ADULT_QUARTERLY_UNITS=10
# WS2_CHILD_QUARTERLY_UNITS=5
# WS2_GRACE_DAYS=3                    # June 19: 3 days inclusive
# WS2_RENOVATION_EXCLUDES_TENANT=true
# WS2_REVIEW_THRESHOLD_DOLLARS=10     # June 19: $10
# WS2_ROUNDING_BIAS=tenant_favor      # tenant_favor | dominion_favor | nearest
# WS1_PAYLOAD_DIR=cache

# ── Podio manual overrides (WS-1; defensive — only used if table exists) ────────
# PODIO_OVERRIDE_TABLE=
# PODIO_OVERRIDE_FIELD=override

# ── WS-6 alerting + WS-8 QuickBooks ingestion ───────────────────────────────────
# OUTLOOK_WEBHOOK_URL=
# QB_CSV_DIR=

# ── Playwright ──────────────────────────────────────────────────────────────────
# HEADLESS=false   # show the browser (required for manual-OTP fallback)
